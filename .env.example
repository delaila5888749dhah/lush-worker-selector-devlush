# ---------------------------------------------------------------------------
# lush-worker-selector — example environment configuration
# Copy to `.env` and fill in real values before running `python -m app`.
# ---------------------------------------------------------------------------

# Feature flag — set to 1 / true / yes to activate production task_fn.
# When off (default) the runtime runs with a no-op stub task_fn.
ENABLE_PRODUCTION_TASK_FN=0

# Path to the pipe-delimited task file consumed by FileTaskLoader.
# Format: recipient_email|amount|card|exp_m|exp_y|cvv[|card2|m|y|cvv2|...]
TASK_INPUT_FILE=tasks/input.txt

# ---------------------------------------------------------------------------
# Telegram notifications (Blueprint §6 Ngã rẽ 2)
# Required when you want success/alert pings to be delivered to Telegram.
# All three must be set; TELEGRAM_ENABLED gates the outbound calls so secrets
# staged in CI/staging remain inert until explicitly turned on.
# ---------------------------------------------------------------------------
TELEGRAM_ENABLED=0
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---------------------------------------------------------------------------
# BitBrowser / proxy infrastructure (referenced by integration.worker_task)
# ---------------------------------------------------------------------------
BITBROWSER_API_KEY=
BITBROWSER_ENDPOINT=

# ---------------------------------------------------------------------------
# Billing pool (production guard: do not point at /tmp — see modules/billing)
# Can be a local folder or a Google Drive Desktop mounted path for VPS sync.
# Examples:
#   Linux/Mac: BILLING_POOL_DIR=/Volumes/GoogleDrive/My Drive/billing_pool
#   Windows:   BILLING_POOL_DIR=G:\My Drive\billing_pool
# See README.md "Production Deployment > Billing pool sync via Google Drive
# Desktop" for setup instructions.
# ---------------------------------------------------------------------------
BILLING_POOL_DIR=billing_pool

# ---------------------------------------------------------------------------
# MaxMind GeoLite2 — offline IP → zip/timezone lookup (no external API calls).
# GEOIP_DB_PATH: path to GeoLite2-City.mmdb, loaded into RAM at startup.
# MAXMIND_LICENSE_KEY: required to download the DB via scripts/download_maxmind.py
#   1. Register at https://www.maxmind.com/en/geolite2/signup
#   2. Generate a license key, set it below.
#   3. Run: MAXMIND_LICENSE_KEY=<key> python scripts/download_maxmind.py
# When ENABLE_PRODUCTION_TASK_FN=1 and GEOIP_DB_PATH is missing, startup aborts.
# MAXMIND_RELOAD_INTERVAL_HOURS: background thread wakes every N hours to
#   check the .mmdb file mtime and hot-swap the reader when the file changes
#   (see README.md "Production Deployment > Auto-update MaxMind .mmdb").
# ---------------------------------------------------------------------------
GEOIP_DB_PATH=data/GeoLite2-City.mmdb
MAXMIND_LICENSE_KEY=
MAXMIND_RELOAD_INTERVAL_HOURS=24

# ---------------------------------------------------------------------------
# Legacy FSM API gate — only set when running legacy-api tests.
# ---------------------------------------------------------------------------
FSM_ALLOW_LEGACY=0
