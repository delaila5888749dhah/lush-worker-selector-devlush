# ---------------------------------------------------------------------------
# lush-worker-selector — example environment configuration
# Copy to `.env` and fill in real values before running `python -m app`.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# RUNTIME — worker pool sizing, feature flags, task loader
# ---------------------------------------------------------------------------
# Feature flag — set to 1 / true / yes to activate production task_fn.
# When off (default) the runtime runs with a no-op stub task_fn.
ENABLE_PRODUCTION_TASK_FN=0

# Operator-configurable worker cap — true upper bound of WorkerPool.
# Blueprint §1: SCALE_STEPS is derived from this value at import/reset.
# Accepted range: [1, 500].  Startup emits a WARNING when value > 100 so
# operators are aware they have opted into the high-concurrency regime.
# MAX_WORKER_COUNT=10

# Desired (initial) worker count — must be ≤ MAX_WORKER_COUNT.
# Defaults to 1 when unset.  Same accepted range as MAX_WORKER_COUNT.
# WORKER_COUNT=1

# Path to the pipe-delimited task file consumed by FileTaskLoader.
# Format: recipient_email|amount|card|exp_m|exp_y|cvv[|card2|m|y|cvv2|...]
TASK_INPUT_FILE=tasks/input.txt

# ---------------------------------------------------------------------------
# Telegram notifications (Blueprint §6 Ngã rẽ 2)
# Required when you want success/alert pings to be delivered to Telegram.
# All three must be set; TELEGRAM_ENABLED gates the outbound calls so secrets
# staged in CI/staging remain inert until explicitly turned on.
# ---------------------------------------------------------------------------
TELEGRAM_ENABLED=0
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional — separate chat for ALERT events; falls back to TELEGRAM_CHAT_ID.
TELEGRAM_ALERT_CHAT_ID=
# Optional — msgs/sec rate limit for the Telegram bot (default 5).
TELEGRAM_RATE_LIMIT=5
# Optional — set to 1/true/yes to emit verbose observability pings.
TELEGRAM_VERBOSE=0
# Optional — override the JSONL path used for failed-payload persistence.
TELEGRAM_PENDING_FILE=telegram_pending.jsonl

# ---------------------------------------------------------------------------
# BITBROWSER — profile pool, fingerprint, proxy infrastructure (§2.1)
# Referenced by integration.worker_task.
# ---------------------------------------------------------------------------
BITBROWSER_API_KEY=
BITBROWSER_ENDPOINT=

# ── BitBrowser Pool Mode (Blueprint §2.1) ─────────────────────────
# Khi bật (=1), bot dùng pool profile có sẵn, gọi
# /browser/update/partial để random fingerprint mỗi cycle,
# tránh bị Operation Password chặn (không create/delete).
# Để =0 giữ hành vi cũ create/delete.
# BITBROWSER_PROFILE_IDS là CSV profile IDs (không khoảng trắng),
# bắt buộc khi POOL_MODE=1. Khuyến nghị N ≥ WORKER_COUNT × 2.
BITBROWSER_POOL_MODE=0
BITBROWSER_PROFILE_IDS=

# BitBrowser API retry budget.  Attempts are total tries including the first
# request.  Wait values are seconds for exponential backoff (defaults 3, 0.5, 8.0).
# BITBROWSER_RETRY_ATTEMPTS=3
# BITBROWSER_RETRY_WAIT_INITIAL_S=0.5
# BITBROWSER_RETRY_WAIT_MAX_S=8.0

# Optional outbound proxy for Givex browser traffic / IP detection.
# Example: http://user:pass@host:port
# PROXY_SERVER=

# ---------------------------------------------------------------------------
# BILLING — billing pool, circuit breaker, payment watchdog
# Production guard: do not point BILLING_POOL_DIR at /tmp — see modules/billing.
# Can be a local folder or a Google Drive Desktop mounted path for VPS sync.
# Examples:
#   Linux/Mac: BILLING_POOL_DIR=/Volumes/GoogleDrive/My Drive/billing_pool
#   Windows:   BILLING_POOL_DIR=G:\My Drive\billing_pool
# See README.md "Production Deployment > Billing pool sync via Google Drive
# Desktop" for setup instructions.
# ---------------------------------------------------------------------------
BILLING_POOL_DIR=billing_pool

# Consecutive billing failures before the runtime trips the billing-specific
# circuit breaker.  Default: 3.
# BILLING_CB_THRESHOLD=3

# Seconds to pause new work after the billing circuit breaker trips.
# Default: 120.
# BILLING_CB_PAUSE=120

# Billing pool load guards.  MIN_BILLING_PROFILES aborts startup when the pool
# is too small.  Default is 0 (disabled) in dev/stub mode.  In production
# (ENABLE_PRODUCTION_TASK_FN=1), the effective minimum is always >= 1 even if
# MIN_BILLING_PROFILES is set to 0 or a negative value, so startup still
# aborts on an empty pool to fail fast instead of raising CycleExhaustedError
# on the first cycle.  MAX_BILLING_PROFILES bounds the number of profiles
# loaded into memory (default 10000, minimum 1).
# MIN_BILLING_PROFILES=1
# MAX_BILLING_PROFILES=10000

# Payment-step watchdog timeout (seconds) — aborts a hung fill_card /
# wait_for_total step before the whole cycle locks up.
# PAYMENT_WATCHDOG_TIMEOUT_S=60

# DOM-only watchdog fallback for Selenium flavors that lack add_cdp_listener.
# Set to 1 only as a degraded-mode escape hatch; preferred fix is
# selenium-wire==5.1.0 for full CDP listener support.
ALLOW_DOM_ONLY_WATCHDOG=0

# ---------------------------------------------------------------------------
# GEO — MaxMind GeoLite2 offline IP → zip/timezone lookup (no external API).
# GEOIP_DB_PATH (preferred): path to GeoLite2-City.mmdb, loaded into RAM at startup.
# MAXMIND_DB_PATH: legacy alias of GEOIP_DB_PATH, accepted for spec/blueprint
#   compatibility. If both are set, GEOIP_DB_PATH wins.
# MAXMIND_LICENSE_KEY: required to download the DB via scripts/download_maxmind.py
#   1. Register at https://www.maxmind.com/en/geolite2/signup
#   2. Generate a license key, set it below.
#   3. Run: MAXMIND_LICENSE_KEY=<key> python scripts/download_maxmind.py
# When ENABLE_PRODUCTION_TASK_FN=1 and the resolved .mmdb path is missing,
# startup aborts.
# MAXMIND_RELOAD_INTERVAL_HOURS: background thread wakes every N hours to
#   check the .mmdb file mtime and hot-swap the reader when the file changes
#   (see README.md "Production Deployment > Auto-update MaxMind .mmdb").
# ---------------------------------------------------------------------------
GEOIP_DB_PATH=data/GeoLite2-City.mmdb
# MAXMIND_DB_PATH=data/GeoLite2-City.mmdb  # legacy alias of GEOIP_DB_PATH
MAXMIND_LICENSE_KEY=
MAXMIND_RELOAD_INTERVAL_HOURS=24

# ---------------------------------------------------------------------------
# Legacy FSM API gate — only set when running legacy-api tests.
# ---------------------------------------------------------------------------
FSM_ALLOW_LEGACY=0

# ---------------------------------------------------------------------------
# Givex URL overrides — for staging/sandbox environments (P2-2).
# Leave unset to use the default production URLs.
# ---------------------------------------------------------------------------
GIVEX_ENDPOINT=
GIVEX_PAYMENT_URL=
GIVEX_EGIFT_URL=
# ALLOW_NON_PROD_GIVEX_HOSTS — staging/sandbox bypass for the Givex host
# allowlist enforced in modules/cdp/driver.py.
#   • Truthy values: 1 / true / yes (case-insensitive). Whitespace ignored.
#   • Anything else — including 0, false, no, empty, or unset — DENIES the
#     bypass and re-enables strict allowlist enforcement.
#   • The HTTPS scheme is ALWAYS required; this flag does NOT permit
#     http:// downgrades or non-https schemes.
#   • MUST NOT be set in production. Only set to 1 for staging/sandbox
#     when GIVEX_PAYMENT_URL/GIVEX_EGIFT_URL point at a non-prod host.
ALLOW_NON_PROD_GIVEX_HOSTS=0

# Optional UTF-8 file with one extra greeting message per line.  Merged
# after the built-in defaults (deduplicated, order preserved).  Lines
# >500 chars are skipped and the total list is capped at 1000 entries.
# Spec §4 — _GREETINGS extensibility without redeploy.
# GIVEX_GREETINGS_FILE=/etc/givex/greetings.txt

# ---------------------------------------------------------------------------
# DELAY — behavioral delay hard caps & watchdog headroom (Blueprint §8.4)
# All values in seconds.  See modules/delay/config.py for validation bounds.
# Leave unset to use the built-in defaults.
# ---------------------------------------------------------------------------
# Hard upper bound per keystroke (default: 0.6).
# DELAY_MAX_TYPING_DELAY=0.6
# Hard upper bound for hesitation pauses inside a field (default: 2.0).
# DELAY_MAX_HESITATION_DELAY=2.0
# Hard upper bound between logical steps (default: 8.0).
# DELAY_MAX_STEP_DELAY=8.0
# Extra headroom (seconds) granted to watchdogs so they never fire before
# the legitimate max step delay elapses (default: 5.0).
# DELAY_WATCHDOG_HEADROOM=5.0
# CDP call timeout shared with the orchestrator (default: 15.0s, must be > 0).
# CDP_CALL_TIMEOUT_SECONDS=15.0
# Legacy misnamed override kept for operator visibility only.  It has NO
# effect; use CDP_CALL_TIMEOUT_SECONDS instead.
# DELAY_CDP_CALL_TIMEOUT=

# Gradual behavior drift (Blueprint §10 temporal variation).
# AR(1) random-walk envelope on typing/thinking delays, clamped to ±30%.
# Default ON; set to 0 to disable for A/B testing.
# ENABLE_GRADUAL_DRIFT=1

# ---------------------------------------------------------------------------
# POPUP — thank-you / legal popup handling (integration/worker_task popup step)
# ---------------------------------------------------------------------------
# Use XPath instead of CSS selectors for popup close-button discovery
# (set to 1 when the target page uses shadow DOM or dynamic class names).
# POPUP_USE_XPATH=0
# Clear the popup-close sentinel after a successful close (default: 1 / true).
# POPUP_CLEAR_AFTER_CLOSE=1
# Maximum attempts to close a popup before giving up and logging a warning.
# POPUP_CLOSE_MAX_RETRIES=3

# ---------------------------------------------------------------------------
# CDP TYPING — strict-mode enforcement for the legacy _cdp_type_field path.
# When set to 1 (production default) any caller that still routes through the
# deprecated send_keys-based _cdp_type_field raises RuntimeError so an
# accidental regression cannot downgrade anti-fraud quality on the §5 hot-path.
# Set to 0 only for legacy tests that explicitly exercise the fallback.
# ---------------------------------------------------------------------------
# ENFORCE_CDP_TYPING_STRICT=1
