# =========================
# APP MODE
# =========================
# 0 = safe/no-op, 1 = production real flow
ENABLE_PRODUCTION_TASK_FN=0

WORKER_COUNT=1
MAX_WORKER_COUNT=1

# =========================
# BITBROWSER
# =========================
BITBROWSER_ENDPOINT=http://127.0.0.1:54345
BITBROWSER_API_KEY=

# 1 = use existing BitBrowser profiles
BITBROWSER_POOL_MODE=1

# CSV profile IDs, no quotes
# Example:
# BITBROWSER_PROFILE_IDS=profile_id_1,profile_id_2
BITBROWSER_PROFILE_IDS=

BITBROWSER_RETRY_ATTEMPTS=3
BITBROWSER_RETRY_WAIT_INITIAL_S=0.5
BITBROWSER_RETRY_WAIT_MAX_S=8.0

# =========================
# WATCHDOG / SELENIUM
# =========================
CDP_CALL_TIMEOUT_SECONDS=15.0
PAYMENT_WATCHDOG_TIMEOUT_S=60

# 0 = require CDP add_cdp_listener
# 1 = temporary DOM polling fallback
ALLOW_DOM_ONLY_WATCHDOG=0

# =========================
# DELAY CONFIG
# Prefer defaults. Only override if needed.
# Must satisfy:
# DELAY_MIN_TYPING_DELAY < DELAY_MAX_TYPING_DELAY
# DELAY_MIN_THINKING_DELAY <= DELAY_MAX_HESITATION_DELAY
# DELAY_MAX_STEP_DELAY + DELAY_WATCHDOG_HEADROOM <= 10
# =========================
# DELAY_MIN_TYPING_DELAY=0.6
# DELAY_MAX_TYPING_DELAY=1.8
# DELAY_MIN_THINKING_DELAY=3.0
# DELAY_MAX_HESITATION_DELAY=5.0
# DELAY_MAX_STEP_DELAY=7.0
# DELAY_WATCHDOG_HEADROOM=3.0

# =========================
# GEO / MAXMIND
# =========================
GEOIP_DB_PATH=data/GeoLite2-City.mmdb
MAXMIND_LICENSE_KEY=
MAXMIND_RELOAD_INTERVAL_HOURS=24

# =========================
# BILLING
# =========================
BILLING_POOL_DIR=billing_pool
# Optional: semicolon-separated external roots allowed for BILLING_POOL_DIR.
# Example Windows Google Drive:
# Forward slashes are accepted by Windows and avoid escaping backslashes in .env files.
# BILLING_POOL_DIR=G:/My Drive/billing_pool
# BILLING_ALLOWED_PREFIXES=G:/My Drive
BILLING_ALLOWED_PREFIXES=
MIN_BILLING_PROFILES=1
MAX_BILLING_PROFILES=10000

# =========================
# GIVEX
# =========================
# Leave empty to use production default URLs from code.
GIVEX_ENDPOINT=
# GIVEX_EGIFT_URL=
# GIVEX_PAYMENT_URL=
ALLOW_NON_PROD_GIVEX_HOSTS=0

# =========================
# OPTIONAL PROXY
# =========================
# Only needed if app uses PROXY_SERVER directly.
# BitBrowser profile proxy can be configured in BitBrowser UI instead.
PROXY_SERVER=
